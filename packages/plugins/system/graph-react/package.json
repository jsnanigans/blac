{
  "name": "@blac/plugin-graph-react",
  "version": "2.0.0-rc.2",
  "description": "React visualization components for @blac/plugin-graph",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "prepublishOnly": "echo 'Skipping prepublishOnly - build should be done at root level'"
  },
  "dependencies": {
    "@visx/group": "^3.12.0",
    "@visx/hierarchy": "^3.12.0",
    "@visx/scale": "^3.12.0",
    "@visx/shape": "^3.12.0",
    "@visx/zoom": "^3.12.0",
    "d3-hierarchy": "^3.1.2",
    "d3-shape": "^3.2.0",
    "framer-motion": "^11.18.2"
  },
  "devDependencies": {
    "@blac/core": "workspace:*",
    "@blac/plugin-graph": "workspace:*",
    "@blac/react": "workspace:*",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/d3-shape": "^3.1.7",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "react": "catalog:",
    "typescript": "catalog:",
    "tsdown": "catalog:"
  },
  "peerDependencies": {
    "@blac/core": "workspace:*",
    "@blac/plugin-graph": "workspace:*",
    "@blac/react": "workspace:*",
    "@radix-ui/react-tooltip": "^1.0.7",
    "react": "^18.0.0 || ^19.0.0"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "blac",
    "plugin",
    "graph",
    "visualization",
    "react",
    "visx",
    "debugging",
    "state-management"
  ],
  "author": "",
  "license": "MIT"
}
