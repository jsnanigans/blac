{
  "name": "@blac/plugin-render-logging",
  "version": "2.0.0-rc.2",
  "description": "Render logging plugin for BlaC state management",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "clean": "rm -rf dist",
    "test": "echo 'No tests yet' && exit 0",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "prepublishOnly": "echo 'Skipping prepublishOnly - build should be done at root level'"
  },
  "dependencies": {},
  "devDependencies": {
    "@blac/core": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "tsdown": "catalog:"
  },
  "peerDependencies": {
    "@blac/core": "workspace:*"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "blac",
    "plugin",
    "render",
    "logging",
    "debugging",
    "state-management"
  ],
  "author": "",
  "license": "MIT"
}
