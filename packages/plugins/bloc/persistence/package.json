{
  "name": "@blac/plugin-persistence",
  "version": "2.0.0-rc.2",
  "description": "Persistence plugin for BlaC state management",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "format": "prettier --write \".\"",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "echo 'Skipping prepublishOnly - build should be done at root level'"
  },
  "keywords": [
    "blac",
    "state-management",
    "persistence",
    "plugin",
    "localStorage",
    "sessionStorage"
  ],
  "author": "BlaC Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/blac/blac",
    "directory": "packages/plugins/bloc/persistence"
  },
  "dependencies": {},
  "devDependencies": {
    "@blac/core": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "prettier": "catalog:",
    "vitest": "catalog:",
    "tsdown": "catalog:"
  },
  "peerDependencies": {
    "@blac/core": "workspace:*"
  }
}
