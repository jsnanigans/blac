{
  "name": "@blac/devtools-ui",
  "version": "2.0.0-rc.7",
  "license": "MIT",
  "author": "Brendan Mullins <jsnanigans@gmail.com>",
  "description": "DevTools UI components for BlaC state management",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jsnanigans/blac.git",
    "directory": "packages/devtools-ui"
  },
  "homepage": "https://github.com/jsnanigans/blac#readme",
  "bugs": {
    "url": "https://github.com/jsnanigans/blac/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.cjs",
    "dist/**/*.d.ts",
    "dist/**/*.d.cts",
    "dist/**/*.map",
    "README.md"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown && tsc -p tsconfig.build.json && cp dist/index.d.ts dist/index.d.cts",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@blac/core": "workspace:*",
    "@blac/react": "workspace:*",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@blac/core": "workspace:*",
    "@blac/react": "workspace:*",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "dependencies": {
    "@uiw/react-json-view": "2.0.0-alpha.39",
    "json-diff-kit": "^1.0.33"
  }
}
