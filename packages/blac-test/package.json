{
  "name": "@blac/test",
  "version": "2.0.3",
  "license": "MIT",
  "author": "Brendan Mullins <jsnanigans@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jsnanigans/blac.git",
    "directory": "packages/blac-test"
  },
  "homepage": "https://github.com/jsnanigans/blac#readme",
  "bugs": {
    "url": "https://github.com/jsnanigans/blac/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist/index.js",
    "dist/index.cjs",
    "dist/index.d.ts",
    "dist/index.d.cts",
    "dist/*.map",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "keywords": [
    "typescript",
    "state-management",
    "blac",
    "testing",
    "test-utils"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "build": "pnpm build:js && pnpm build:types",
    "build:js": "tsdown",
    "build:types": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@blac/core": "workspace:*"
  },
  "peerDependencies": {
    "vitest": ">=1.0.0"
  },
  "devDependencies": {
    "@blac/core": "workspace:*",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
