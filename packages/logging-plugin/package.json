{
  "name": "@blac/logging-plugin",
  "version": "2.0.0-rc.17",
  "type": "module",
  "license": "MIT",
  "author": "Brendan Mullins <jsnanigans@gmail.com>",
  "description": "Logging and debugging plugin for BlaC state management",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jsnanigans/blac.git",
    "directory": "packages/logging-plugin"
  },
  "homepage": "https://github.com/jsnanigans/blac#readme",
  "bugs": {
    "url": "https://github.com/jsnanigans/blac/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.cjs",
    "dist/**/*.d.ts",
    "dist/**/*.d.cts",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "keywords": [
    "blac",
    "logging",
    "debugging",
    "state-management",
    "devtools"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown && tsc -p tsconfig.build.json && cp dist/index.d.ts dist/index.d.cts",
    "clean": "rm -rf dist",
    "format": "prettier --write \".\"",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "echo 'Skipping prepublishOnly - build should be done at root level'",
    "deploy": "pnpm publish --access public"
  },
  "peerDependencies": {
    "@blac/core": "workspace:*"
  },
  "devDependencies": {
    "@blac/core": "workspace:*",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "tsdown": "catalog:"
  }
}
