{
  "manifest_version": 3,
  "name": "BlaC DevTools",
  "version": "1.0.0",
  "description": "DevTools extension for BlaC state management library",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "dist/background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content/content-script.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "devtools_page": "dist/src/devtools/devtools.html",
  "action": {
    "default_popup": "dist/src/popup/popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["dist/inject/inject-script.js"],
      "matches": ["<all_urls>"]
    }
  ]
}