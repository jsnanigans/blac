{
  "compilerOptions": {
    "target": "es2021",
    "module": "esnext",
    "lib": ["esnext", "dom"],
    "sourceMap": true,
    "strict": true,
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "experimentalDecorators": true,
    "resolveJsonModule": true,
    "paths": {
      "@blac/core": ["../blac-core/src/index.ts"],
      "@blac/core/tracking": ["../blac-core/src/tracking.ts"]
    }
  },
  "include": ["src"],
  "exclude": []
}
