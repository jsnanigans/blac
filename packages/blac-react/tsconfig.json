{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "lib": ["esnext", "dom"],
    "jsx": "react-jsx",
    "sourceMap": true,
    "outDir": "dist",
    "strict": true,
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "experimentalDecorators": true,
    "resolveJsonModule": true,
    "types": ["vitest/globals", "@testing-library/jest-dom"],
    "paths": {
      "@blac/core": ["../blac/src/index.ts"]
    }
  },
  "include": [
    "src",
    "tests",
    "vite.config.ts",
    "vitest-setup.ts",
    "vitest.d.ts"
  ],
  "exclude": ["publish.ts", "dev.ts"]
}
