{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "./src",
    "noEmit": false,
    "declaration": true,
    "declarationMap": false,
    "emitDeclarationOnly": true
  },
  "include": ["src"],
  "exclude": ["src/__tests__", "src/__archived__", "**/*.test.ts"]
}
