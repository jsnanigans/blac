{
  "name": "@blac/core",
  "version": "2.0.8",
  "license": "MIT",
  "author": "Brendan Mullins <jsnanigans@gmail.com>",
  "description": "Type-safe, class-based state management with proxy tracking and plugin system",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jsnanigans/blac.git",
    "directory": "packages/blac-core"
  },
  "homepage": "https://github.com/jsnanigans/blac#readme",
  "bugs": {
    "url": "https://github.com/jsnanigans/blac/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./tracking": {
      "import": {
        "types": "./dist/tracking.d.ts",
        "default": "./dist/tracking.js"
      },
      "require": {
        "types": "./dist/tracking.d.cts",
        "default": "./dist/tracking.cjs"
      }
    },
    "./debug": {
      "import": {
        "types": "./dist/debug.d.ts",
        "default": "./dist/debug.js"
      },
      "require": {
        "types": "./dist/debug.d.cts",
        "default": "./dist/debug.cjs"
      }
    },
    "./plugins": {
      "import": {
        "types": "./dist/plugins.d.ts",
        "default": "./dist/plugins.js"
      },
      "require": {
        "types": "./dist/plugins.d.cts",
        "default": "./dist/plugins.cjs"
      }
    },
    "./watch": {
      "import": {
        "types": "./dist/watch-entry.d.ts",
        "default": "./dist/watch-entry.js"
      },
      "require": {
        "types": "./dist/watch-entry.d.cts",
        "default": "./dist/watch-entry.cjs"
      }
    },
    "./types": {
      "import": {
        "types": "./dist/types.d.ts",
        "default": "./dist/types.js"
      },
      "require": {
        "types": "./dist/types.d.cts",
        "default": "./dist/types.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "keywords": [
    "typescript",
    "state-management",
    "observer-pattern",
    "bloc",
    "bloc-pattern"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown && tsc -p tsconfig.build.json && for f in dist/*.d.ts; do cp \"$f\" \"${f%.d.ts}.d.cts\"; done",
    "clean": "rm -rf dist",
    "format": "prettier --write \".\"",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "coverage": "vitest run --coverage",
    "verify": "node ../../scripts/run-workspace-bin.mjs publint",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "echo 'Skipping prepublishOnly - build should be done at root level'",
    "deploy": "pnpm publish --access public"
  },
  "devDependencies": {
    "@blac/test": "workspace:*",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/user-event": "catalog:",
    "@vitest/browser": "catalog:",
    "arktype": "^2.1.23",
    "fast-check": "^4.3.0",
    "jsdom": "catalog:",
    "prettier": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "valibot": "^1.1.0",
    "vitest": "catalog:",
    "publint": "catalog:",
    "zod": "^4.1.12"
  }
}
