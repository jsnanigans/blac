{
  "name": "@blac/devtools-connect",
  "version": "2.0.0-rc.2",
  "license": "MIT",
  "author": "Brendan Mullins <jsnanigans@gmail.com>",
  "description": "DevTools connection plugin for BlaC state management",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "keywords": [
    "blac",
    "devtools",
    "debugging",
    "state-management",
    "time-travel"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown",
    "clean": "rm -rf dist",
    "format": "prettier --write \".\"",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "echo 'Skipping prepublishOnly - build should be done at root level'",
    "deploy": "pnpm publish --access public"
  },
  "peerDependencies": {
    "@blac/core": "workspace:*"
  },
  "devDependencies": {
    "@blac/core": "workspace:*",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "tsdown": "catalog:"
  }
}
