{
  "name": "@blac/devtools-connect",
  "version": "2.0.6",
  "license": "MIT",
  "author": "Brendan Mullins <jsnanigans@gmail.com>",
  "description": "DevTools connection plugin for BlaC state management",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jsnanigans/blac.git",
    "directory": "packages/devtools-connect"
  },
  "homepage": "https://github.com/jsnanigans/blac#readme",
  "bugs": {
    "url": "https://github.com/jsnanigans/blac/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "keywords": [
    "blac",
    "devtools",
    "debugging",
    "state-management",
    "time-travel"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown && tsc -p tsconfig.build.json && cp dist/index.d.ts dist/index.d.cts",
    "clean": "rm -rf dist",
    "format": "prettier --write \".\"",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "test": "node ../../scripts/run-workspace-bin.mjs vitest run --passWithNoTests",
    "verify": "node ../../scripts/run-workspace-bin.mjs publint",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "echo 'Skipping prepublishOnly - build should be done at root level'",
    "deploy": "pnpm publish --access public"
  },
  "peerDependencies": {
    "@blac/core": "workspace:^"
  },
  "devDependencies": {
    "@blac/core": "workspace:*",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "publint": "catalog:",
    "tsdown": "catalog:"
  }
}
