{
  "name": "blac",
  "version": "0.0.1",
  "scripts": {
    "dev": "vp run -F './apps/*' dev",
    "build": "vp run -F './packages/*' build",
    "clean": "vp run -F './packages/*' -F './apps/*' clean",
    "test": "vp run -F './packages/*' test",
    "test:watch": "vp run -F './packages/*' test:watch",
    "lint": "vp run -F './packages/*' lint",
    "lint:fix": "vp run -F './packages/*' lint:fix",
    "verify": "vp run -F './packages/*' verify",
    "typecheck": "vp run -F './packages/*' typecheck",
    "format": "vp run -F './packages/*' -F './apps/*' format",
    "docs:api": "node scripts/generate-api-docs.mjs",
    "docs:dev": "pnpm --filter @blac/docs dev",
    "docs:build": "pnpm --filter @blac/docs build",
    "docs:preview": "pnpm --filter @blac/docs preview",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release:check": "pnpm build && pnpm verify && pnpm test && pnpm typecheck",
    "release:version": "changeset version",
    "release:publish": "pnpm release:check && changeset publish",
    "release": "./scripts/release.sh",
    "release:helper": "./scripts/release.sh",
    "docs:changelog": "node scripts/generate-changelog.mjs",
    "prepare": "vp config"
  },
  "type": "module",
  "pnpm": {},
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.5",
    "@microsoft/api-documenter": "^7.28.1",
    "@microsoft/api-extractor": "^7.52.8",
    "@types/bun": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "packageManager": "pnpm@10.14.0"
}
