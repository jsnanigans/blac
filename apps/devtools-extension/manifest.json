{
  "manifest_version": 3,
  "name": "BlaC DevTools",
  "version": "2.0.3",
  "description": "Chrome DevTools extension for BlaC state management",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [],
  "host_permissions": [],
  "background": {
    "service_worker": "dist/background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content/content-script.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "devtools_page": "dist/src/devtools/devtools.html",
  "action": {
    "default_popup": "dist/src/popup/popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["dist/inject/inject-script.js", "dist/chunks/*.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
