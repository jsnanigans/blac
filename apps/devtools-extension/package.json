{
  "name": "@blac/devtools-extension",
  "version": "2.0.1",
  "description": "Chrome DevTools extension for BlaC state management",
  "private": true,
  "scripts": {
    "dev": "vp dev",
    "build:app": "vp build",
    "preview": "vp preview",
    "typecheck": "tsc --project tsconfig.typecheck.json --noEmit",
    "typecheck:all": "tsc --noEmit",
    "clean": "rm -rf dist",
    "package:webstore": "pnpm build:app && rm -f webstore.zip && zip -r webstore.zip manifest.json icons dist -x '*.map'"
  },
  "dependencies": {
    "@blac/core": "workspace:*",
    "@blac/react": "workspace:*",
    "@blac/devtools-ui": "workspace:*"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.254",
    "@types/node": "^20.10.0",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^4.2.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "typescript": "^5.3.3",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  }
}
