{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // Chrome extension environment
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["chrome", "vite/client"],
    "sourceMap": true,

    // Skip checking declaration files from dependencies
    "skipLibCheck": true,

    // Don't follow imports into node_modules or dependencies
    "noResolve": false,

    // Path aliases
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
