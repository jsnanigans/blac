{
  "packages": {
    "include": [
      "packages/*",
      "packages/plugins/**"
    ],
    "exclude": [
      "packages/test-utils",
      "packages/internal-*"
    ],
    "pattern": "@blac/*"
  },
  "publish": {
    "defaultTag": "preview",
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "gitChecks": false
  },
  "build": {
    "command": "pnpm run build",
    "required": true
  },
  "version": {
    "gitTag": false,
    "allowedBumps": ["patch", "minor", "major", "prerelease"],
    "syncWorkspaceDependencies": true
  },
  "hooks": {
    "prepublish": "",
    "postpublish": ""
  }
}